---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import InnerHero from '../../components/sections/InnerHero.astro';
import Carousel from '../../components/sections/Carousel.astro';
import Button from '../../components/ui/Button.astro';
import heroImage from '../../assets/images/home/default-hero.jpg';
import pipetteImage from '../../assets/images/home/about.jpg';
import ianLungImage from '../../assets/images/home/developer.jpg';
import lung3dImage from '../../assets/images/lung3d.png';

// Get research-area markdown files
const areaEntries = await getCollection('areas');

// Sort the entries to ensure consistent order
const sortedAreas = areaEntries.sort((a, b) => {
  const order = ['mechanisms', 'support', 'physiology'];
  return order.indexOf(a.id) - order.indexOf(b.id);
});

// Create carousel slides from research areas
const carouselSlides = sortedAreas.map((area, index) => ({
  title: area.data.title,
  description: area.data.subtitle || `Explore our research in ${area.data.title}`,
  image: [pipetteImage, ianLungImage, lung3dImage][index % 3],
  buttons: [
    {
      text: 'Learn More',
      link: `/research-areas/${area.id}`,
      variant: 'primary',
    }
  ]
}));

// Hero content
const heroContent = {
    title: 'Research at the ASPIRE Lab',
    backgroundImage: heroImage,
    description: 'Redefining Organ Support Through Integrated Physiology, Engineering, and Intelligent Systems',
    overlayOpacity: 0.8,
};
---

<Layout title="Research Areas">
    <InnerHero content={heroContent} />

    

    <!-- Publications Button Section -->
    <section class="py-small bg-stone-50">
        <div class="site-container--small mx-auto px-8">
            <p class="mb-8 text-lg text-stone-600">
                At the ASPIRE Lab, our research is organized around three interconnected pillars that together aim to transform how organ failure is understood, supported, and treated. 
                We integrate <a href="/research-areas/mechanisms">systems-level physiology</a>, <a href="/research-areas/support">advanced engineering</a>, and <a href="/research-areas/physiology">computational modeling</a> to develop mechanistically grounded and data-driven approaches that improve patient outcomes.
            </p>
            <p class="mb-8 text-lg text-stone-600">
                Rather than separating discovery, technology development, and data science, we unify them. 
                Experimental platforms inform device innovation. Clinical data refine computational models. Engineering solutions are evaluated within physiologic frameworks. Across all efforts, our focus remains constant: to define the physiologic state of failing organs and design technologies and strategies that restore function safely and effectively.
            </p>
            </div>
            <center><Button 
                href="/publications" 
                variant="primary"
                size="md"
            >View Publications</Button></center>
        </div>
    </section>

    <!-- Carousel Section -->
    <Carousel slides={carouselSlides} />

</Layout>
