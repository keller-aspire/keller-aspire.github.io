---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/sections/Hero.astro';
import Button from '@components/ui/Button.astro';
import SplitPanel from '@components/sections/SplitPanel.astro';
import CtaBanner from '@components/sections/CtaBanner.astro';
import Faqs from '@components/sections/Faqs.astro';
import { faqLists } from '@data/faqs';
import Carousel from '@components/sections/Carousel.astro';
import heroImage from '../assets/images/home/default-hero-2.jpg';
import heroImage2 from '../assets/images/home/default-hero.jpg';
import heroImage3 from '../assets/images/home/dome.jpg';
import heroImage4 from '../assets/images/home/or.jpeg';
import heroImage5 from '../assets/images/home/or2.jpeg';
import styleGuideImage from '../assets/images/home/developer.jpg';
import teamImage from '../assets/images/home/meet-the-team.jpg';

const seoTitle = "Aspire Lab";
const seoDescription = "Advanced Systems Physiology, Innovation, & Regenerative Engineering";

const heroContent = {
    title: 'ASPIRE Lab: Advanced Systems Physiology and Innovative Regenerative Engineering',
    description: 'Redefining Patient Care at the Interface of Physiology, Engineering, and Intelligent Systems',
    buttons: [
        {
            text: 'Our Vision',
            link: '/vision',
        }
    ],
    backgroundImage: heroImage4,
    overlayOpacity: 0.85
}

const originalHeroContent = {
    title: 'Innovate. It\'s what we do.',
    description: 'Redefining the intersection between the bench and the bedside: shaping clinical practice through advanced science, engineering, and design. We aspire to bring healthcare\'s tomorrow to today\'s patients.',
    buttons: [
        {
            text: 'Our Research',
            link: '/research-areas',
        }
    ],
    backgroundImage: heroImage,
    overlayOpacity: 0.2
}

const carouselSlides = [
    {
        title: "Cutting-Edge Research",
        description: "Pushing the boundaries of science and technology to develop innovative healthcare solutions.",
        image: heroImage,
        buttons: [
            {
                text: "Learn More",
                link: "/research",
                variant: "primary" as const
            }
        ]
    },
    {
        title: "Collaborative Innovation",
        description: "Fostering partnerships across disciplines to drive transformative advancements in medicine.",
        image: heroImage2,
        buttons: [
            {
                text: "Our Partners",
                link: "/partners",
                variant: "primary" as const
            }
        ]
    },
    {
        title: "Collaborative Innovation",
        description: "Fostering partnerships across disciplines to drive transformative advancements in medicine.",
        image: styleGuideImage,
        buttons: [
            {
                text: "Our Partners",
                link: "/partners",
                variant: "primary" as const
            }
        ]
    }
];

const team = {
    eyebrow: "People",
    headline: "The ASPIRE Team",
    description: "The ASPIRE Lab unites researchers, clinicians, and engineers in a collaborative environment to advance the understanding and treatment of organ failure.",
    image: {
        src: teamImage,
        alt: "ASPIRE Lab Photo Wall"
    },
    buttons: [
        {
            text: "Our Team",
            link: "/team",
            variant: "primary" as const
        },
        {
            text: "Join Us",
            link: "/contact",
            variant: "primary" as const
        }
    ]
}

const faqsSection = {
    eyebrow: "Publications",
    title: 'Featured ASPIRE Lab Publications',
    description: 'Read more about our latest research.',
    faqs: faqLists.main.faqs
}
---

<Layout title={seoTitle} description={seoDescription}>
    <Hero content={heroContent} />
    <section class="py-small bg-stone-50">
        <div class="site-container--small mx-auto px-8">
            <p class="mb-8 text-lg text-stone-600">
                The ASPIRE Lab builds next-generation, patient-centered technologies by translating systems physiology into engineered solutions. 
                Led by a physician-engineer, we create mechanistically grounded and data-driven approaches that move care from reactive rescue to precise, personalized intervention.
            </p>
            <p class="mb-8 text-lg text-stone-600">
                Our work combines translational experimental models, advanced organ support and regenerative engineering, and AI-enabled analysis of high-resolution physiologic monitoring data. 
                This integrated capability allows us to discover how organs fail and recover — and to design smarter therapies and support systems that measurably improve patient outcomes across healthcare.
            </p>
            <p class="mb-8 text-lg text-stone-600">
                We aspire to transform how organ failure is understood, supported, and ultimately healed.
            </p>
            </div>
            <center><Button 
                href="/research-areas" 
                variant="primary"
                size="md"
            >Our Research</Button></center>
        </div>
    </section>
    <SplitPanel content={team} imagePosition="right" background="light" padding="base" />
    <Faqs content={faqsSection} background="base" padding="base" />
</Layout>