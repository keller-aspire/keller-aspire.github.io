---
import { Github, Linkedin, Mail, Stethoscope, GraduationCap, School, University, Hospital, Microscope} from 'lucide-astro';
import { getCollection, render } from 'astro:content';
import { getPaddingClass } from '@utils/styleUtils';
import type { PaddingSize } from '@utils/styleUtils';
import { Image } from 'astro:assets';

interface Props {
    padding?: PaddingSize;
    paddingTop?: PaddingSize;
    paddingBottom?: PaddingSize;
    category?: 'PI' | 'Postdoc' | 'PhD' | 'Staff' | 'Current' | 'Past';
    title?: string;
}

const { padding, paddingTop, paddingBottom, category, title } = Astro.props;
const paddingClass = getPaddingClass({ padding, paddingTop, paddingBottom });

const teamMembers = await getCollection('team', ({ data }) => {
    const isPublished = data.publish !== false;
    const matchesCategory = category ? data.category === category : true;
    return isPublished && matchesCategory;
});

// Sort team members by order
const sortedTeamMembers = teamMembers.sort((a, b) => a.data.order - b.data.order);
---

<section class:list={['relative', paddingClass]}>
    <div class="bg-primary-dark text-white inline-block px-12 py-4">
        <h2>{title}</h2>
    </div>
    <div class="site-container mx-auto px-4 mt-8 justify-center">
        <div class="grid grid-cols-2 sm: grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 xl:gap-x-8 xl:gap-y-14">
            {
                sortedTeamMembers.map(({ data: member, id: memberId }, index) => (
                    <div
                        class="flex flex-col bg-primary"
                        data-aos="fade-up"
                        data-aos-delay={index * 100}
                        data-aos-duration="800"
                    >
                        <div class="flex flex-col gap-4 items-start bg-white p-4">
                            <div class="relative overflow-hidden group w-full">
                                <span class="absolute inset-0 -mt-12 h-400 w-1/2 translate-x-[250%] rotate-12 bg-white opacity-20 group-hover:transition-all group-hover:duration-300 ease-out group-hover:translate-x-[-250%] z-10" />
                                {member.headshot ? (
                                    (() => {
                                        const rawAlt = member.altImg ?? member.headshot2;
                                        const altImg = rawAlt && typeof rawAlt === 'string' ? null : rawAlt;
                                        return (
                                            <div class="relative w-full aspect-[3/4] overflow-hidden">
                                                <Image
                                                    src={member.headshot}
                                                    alt=""
                                                    width={896}
                                                    height={1280}
                                                    quality={80}
                                                    format="webp"
                                                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-in-out translate-x-0 group-hover:-translate-x-full z-10"
                                                    loading="eager"
                                                    decoding="async"
                                                />
                                                {altImg && (
                                                    <Image
                                                        src={altImg}
                                                        alt=""
                                                        width={896}
                                                        height={1280}
                                                        quality={80}
                                                        format="webp"
                                                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-in-out translate-x-full group-hover:translate-x-0 z-20"
                                                        loading="eager"
                                                        decoding="async"
                                                    />
                                                )}
                                            </div>
                                        );
                                    })()
                                ) : (
                                    <div class="w-full aspect-[3/4] bg-gray-200 flex items-center justify-center">
                                        <span class="text-gray-400">No Image</span>
                                    </div>
                                )}
                            </div>

                            <div class="flex-1">
                                {member.hasPage ? (
                                    <a href={`/team/${memberId}`} class="group">
                                        <h3 class="text-h5 font-medium transition-colors duration-500 group-hover:text-primary group-hover:underline">
                                            {member.name}{member.degree && `, ${member.degree}`}
                                        </h3>
                                    </a>
                                ) : (
                                    <h3 class="text-h5 font-medium">
                                        {member.name}{member.degree && `, ${member.degree}`}
                                    </h3>
                                )}
                                <p class="text-small text-body-base">{member.jobTitle}</p>

                                {member.email && (
                                    <a
                                        href={`mailto:${member.email}`}
                                        class="flex items-center gap-2 text-xsmall hover:text-primary transition-colors"
                                    >
                                        <Mail size={14} strokeWidth={1.25} />
                                        <span class="break-all">{member.email}</span>
                                    </a>
                                )}

                                {member.github && (
                                    <a
                                        href={member.github}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="flex items-center gap-2 text-xsmall hover:text-primary transition-colors"
                                    >
                                        <Github size={14} strokeWidth={1.25} />
                                        <span class="break-all">{member.githubUsername}</span>
                                    </a>
                                )}

                                {member.linkedin && (
                                    <a
                                        href={member.linkedin}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="flex items-center gap-2 text-xsmall hover:text-primary transition-colors"
                                    >
                                        <Linkedin size={14} strokeWidth={1.25} />
                                        <span class="break-all">{member.linkedinUsername}</span>
                                    </a>
                                )}
                            </div>
                        </div>

                        {(member.researchInterests || member.hobbies) && (
                            <div class="m-4 text-white text-xsmall space-y-2">
                                {member.researchInterests && (
                                    <p>
                                        <strong>Research Interests:</strong> {member.researchInterests}
                                    </p>
                                )}

                                {member.hobbies && (
                                    <p>
                                        <strong>Hobbies:</strong> {member.hobbies}
                                    </p>
                                )}
                            </div>
                        )}
                    </div>
                ))
            }
        </div>
    </div>
</section>
